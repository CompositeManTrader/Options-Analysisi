# .streamlit/secrets.toml — PLANTILLA PÚBLICA
# ─────────────────────────────────────────────────────────────────────────────
# Este archivo muestra el FORMATO esperado de los secrets.
# Para usar localmente:
#   1. Copia este archivo a .streamlit/secrets.toml  (sin el .example)
#   2. Rellena tus credenciales reales
#   El archivo real está en .gitignore y nunca se sube al repo.
#
# Para Streamlit Cloud:
#   App dashboard → Settings → Secrets → pega el contenido con tus valores
# ─────────────────────────────────────────────────────────────────────────────

APP_KEY      = "tu_app_key_aqui"
APP_SECRET   = "tu_app_secret_aqui"
CALLBACK_URL = "https://127.0.0.1"
